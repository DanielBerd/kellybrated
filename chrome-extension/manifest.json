{
  "manifest_version": 3,
  "name": "Manifolio (kelly-manifold)",
  "version": "1.0.0",
  "description": "Kelly bet size calculator for Manifold Markets",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
